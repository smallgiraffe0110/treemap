# ──────────────────────────────────────────────────────────────
# CORE DEMO — works with any one of these LLM providers
# ──────────────────────────────────────────────────────────────

# Option A — Anthropic Claude (sign up at console.anthropic.com)
ANTHROPIC_API_KEY=

# Option B — Google Gemini (free tier at aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Option C — CoreWeave (OpenAI-compatible vLLM endpoint). Highest priority.
COREWEAVE_BASE_URL=
COREWEAVE_API_KEY=
COREWEAVE_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Priority: CoreWeave > Gemini > Anthropic.

# ──────────────────────────────────────────────────────────────
# Observability — Weights & Biases Weave
# ──────────────────────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=treemap-agents

# ──────────────────────────────────────────────────────────────
# Storm Notifier — Resend (free 100/day at resend.com)
# Leave ENABLE_REAL_EMAIL unset to render previews instead of sending.
# ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
ENABLE_REAL_EMAIL=
NOTIFY_FROM=onboarding@resend.dev
NOTIFY_TEST_TO=

# ──────────────────────────────────────────────────────────────
# Voice Agent — Twilio (free trial at twilio.com)
# Leave ENABLE_REAL_VOICE unset for preview-only (no real call placed).
# ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=        # your Twilio phone number, e.g. +15555550100
TWILIO_TEST_TO=           # for demo: a phone number you own, e.g. +15555550199
ENABLE_REAL_VOICE=        # set "1" to actually place calls; otherwise preview only
NEXT_PUBLIC_BASE_URL=     # used as the callback URL (e.g. https://abc123.ngrok.io)

# ──────────────────────────────────────────────────────────────
# Optional extras
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NASA_FIRMS_KEY=
